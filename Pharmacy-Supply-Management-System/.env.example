# ─────────────────────────────────────────────
# Pharmacy Supply Management System — .env
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Flask secret key (generate a strong random string for production)
SECRET_KEY=your-very-secret-key-change-this

# Admin credentials
ADMIN_USERNAME=owner
ADMIN_PASSWORD=YourStrongPassword@123
# OR use a pre-hashed password (preferred for production):
# ADMIN_PASSWORD_HASH=<output of generate_password_hash('yourpassword')>

# Database (leave blank to use local SQLite fallback)
DATABASE_URL=postgresql://user:password@host:5432/pharmacy_db

# Session timeout in minutes (default: 30)
SESSION_TIMEOUT_MINUTES=30

# Set to false to disable demo seed data in production
SEED_DATA=true

# Flask run mode (set to false in production)
FLASK_DEBUG=false
